;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GBeatEmUp"
run/main_scene="uid://5mt5l7tvn7f2"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/stretch_mode=0
config/icon="res://icon.svg"

[autoload]

PlayerInventory="*res://script/player_inventory.gd"
PauseMenu="*uid://cs2x41a0pdcjg"
MusicManager="*uid://cgwfxu3lx04ax"
FxManager="*uid://drearlh5o4yaf"
SurvivalStats="*res://script/survival_stats.gd"
PlayerState="*res://script/player_state.gd"
DialogueDatabase="*uid://cy0sq4dwp8x0k"
DialogManager="*res://script/dialog_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

